{
  "description": "PostToolUse hook to validate PPTX files after write/edit operations",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-pptx-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
